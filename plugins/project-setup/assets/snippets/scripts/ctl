#!/usr/bin/env bash
# ctl — <PROJECT> control plane.  Drop at repo root (chmod +x, no extension — it's the public API).
#
# TEMPLATE, not a fixed spec. This is a sensible default toolkit — copy `ctl` + `scripts/`, then
# add / remove / edit commands to fit the project (most repos won't need every command here).
# To add a command: drop `scripts/<category>/<name>.sh` (category ∈ dev|container|config, see
# common/_lib.sh for the worker preamble) and wire one `run <category>/<name>` line into the case below.
#
# A THIN ROUTER. It sources scripts/common/_lib.sh, dispatches each subcommand to its worker
# (scripts/<category>/<name>.sh), and inlines only the trivial `docker compose` passthroughs.
# Every command supports -h / --help; colors auto-disable when piped or NO_COLOR is set.
#
#   Development    dev · migrate · test · lint
#   Containers     up · down · restart · logs · ps · exec · build · clean · health · shell
#   Configuration  setup · status
#
# PROFILE-LESS 2-axis model. `ctl up` takes an optional standalone `config` (a
# compose.<name>.yaml that REPLACES base — e.g. `data` = just the data layer) plus stackable
# `--modifier "a,b"` overlays (compose.m.<name>.yaml). Bare `ctl up` is interactive
# (config → modifiers → plan → confirm). No `ctl prod` verb — prod is `ctl up prod`. Profiles
# are a rare advanced escalation (see references/2-repo/05-ctl-scripts-tooling/03_complex-setups.md), not part of this default.
# Run `ctl <command> --help` for any command.

set -euo pipefail
CTL_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$CTL_ROOT/scripts/common/_lib.sh"
cd "$CTL_ROOT"

# route to a worker: ctl <cmd> → exec scripts/<file>.sh, passing the rest verbatim
run() { local s="$CTL_ROOT/scripts/$1.sh"; shift; [[ -f $s ]] || die "missing $s — ship it in scripts/"; exec bash "$s" "$@"; }

ctl_help() {
  printf '%s%s%s — control plane. One entrypoint for dev + containers.\n\n' "$C_B$C_CYN" "ctl" "$C_RESET"
  printf '%sDevelopment%s (host loop)\n' "$C_B" "$C_RESET"
  row "dev [target]"                     "apps on host, hot reload (auto-starts data core)"
  row 'migrate {up|down|new|status}'     "database migrations (Alembic)"
  row "test [backend|frontend]"          "run test suites"
  row "lint [backend|frontend]"          "lint backend + frontend"
  printf '\n%sContainers%s (docker compose)\n' "$C_B" "$C_RESET"
  row "up [config] [--modifier …]"       "assemble + start the stack — interactive  (ctl up --help)"
  row "down [svc]"                       "stop the stack (or one service)"
  row "restart [svc]"                    "restart the stack (or one service)"
  row "logs [svc] [-f]"                  "tail container logs"
  row "ps"                               "list running containers + host procs"
  row "exec <svc> [cmd]"                 "run a command in a container (default: shell)"
  row "shell <svc>"                      "open a client/shell in a container (psql, redis-cli, …)"
  row "build"                            "build the service images"
  row "clean [-y]"                       "tear down + wipe volumes/images (asks first)"
  row "health [svc…]"                    "one-shot container health table"
  printf '\n%sConfiguration%s\n' "$C_B" "$C_RESET"
  row "setup"                            "seed .env, generate secrets, data dirs, install deps"
  row "status"                           "config doctor (env · runtimes · deps · health · stack)"
  printf '\n%sup axes%s   configs: %s  modifiers: %s\n' "$C_DIM" "$C_RESET" "$(list_configs | join_sp | or_none)" "$(list_modifiers | join_sp | or_none)"
  printf '%s-h/--help works on every command:  ctl <command> --help%s\n' "$C_DIM" "$C_RESET"
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  # ── development ──────────────────────────────────────────
  dev)      run dev/host    "$@" ;;
  migrate)  run dev/migrate "$@" ;;
  test)     run dev/test    "$@" ;;
  lint)     run dev/lint    "$@" ;;
  # ── containers: substantive workers ──────────────────────
  up)       run container/up     "$@" ;;
  build)    run container/build  "$@" ;;
  clean)    run container/clean  "$@" ;;
  health)   run container/health "$@" ;;
  shell)    run container/shell  "$@" ;;
  ps)       run container/ps     "$@" ;;       # containers + host dev processes
  # ── containers: thin docker compose passthroughs (uniform help + native hint) ──
  # require_env before every dc call: compose interpolates ${VAR} for ALL subcommands
  # (down included), so a `${X:?}` in a compose file would make an env-less `ctl down`
  # fail — a stack you can start but not stop. require_env is non-clobbering + idempotent.
  down)     is_help "${1:-}" && { passthrough_help down    "stop the stack (or one service)";    exit 0; }; require_env; dc down    "$@" ;;
  restart)  is_help "${1:-}" && { passthrough_help restart "restart the stack (or one service)"; exit 0; }; require_env; dc restart "$@" ;;
  logs)     is_help "${1:-}" && { passthrough_help logs    "tail container logs (-f to follow)"; exit 0; }; require_env; dc logs    "$@" ;;
  exec)     is_help "${1:-}" && { print_help exec "Run a command inside a running service container." \
              'exec <service> [command…] [-h]' \
              $'Arguments\n  service       the compose service (e.g. backend, postgres)\n  command…      default: an interactive shell\n\nOptions\n  -h, --help    show this help' \
              "Forwards to \`docker compose exec\`."; exit 0; }
            [[ $# -ge 1 ]] || die "usage: ctl exec <service> [command…]"
            require_env
            svc="$1"; shift; if (( $# )); then dc exec "$svc" "$@"; else dc exec "$svc" sh; fi ;;
  # ── configuration ────────────────────────────────────────
  setup)    run config/setup  "$@" ;;
  status)   run config/status "$@" ;;
  # ── meta ─────────────────────────────────────────────────
  help|-h|--help) ctl_help ;;
  *)        err "unknown command: $cmd"; say "run ${C_B}ctl --help${C_RESET} for the command list"; exit 1 ;;
esac
