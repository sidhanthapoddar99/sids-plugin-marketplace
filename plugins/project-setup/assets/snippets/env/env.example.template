# <PROJECT> — environment contract
#
# Copy to .env and fill in REQUIRED blanks. Secrets must be GENERATED,
# never invented:
#   openssl rand -hex 32           # for HMAC / JWT signing keys
#   openssl rand -base64 32        # for passwords
#   openssl rand -base64 16        # for shorter tokens
#
# Lines marked REQUIRED must be set before `ctl dev` will start (run `ctl setup` to fill them).
# Others have sensible defaults in compose / config.yaml.

# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development                 # development | staging | production
LOG_LEVEL=info                      # debug | info | warn | error
DOMAIN=localhost
TZ=Asia/Kolkata

# ── Database (Postgres) ──────────────────────────────────────────────
POSTGRES_USER=myapp
POSTGRES_PASSWORD=                  # REQUIRED — openssl rand -hex 32
POSTGRES_DB=myapp
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=                     # REQUIRED — openssl rand -hex 32
REDIS_PORT=6379

# ── Auth ─────────────────────────────────────────────────────────────
JWT_SIGNING_KEY=                    # REQUIRED — openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=86400

# ── Encryption (only if you store encrypted-at-rest data) ────────────
ENCRYPTION_KEY_PRIMARY=             # REQUIRED — openssl rand -hex 32
ENCRYPTION_KEY_SECONDARY=           # for rotation — openssl rand -hex 32

# ── Service ports (host-side, for dev) ───────────────────────────────
PYTHON_HOST=0.0.0.0
PYTHON_PORT=8000
# Add per-backend ports as needed:
# RUST_HOST=0.0.0.0
# RUST_PORT=8080

# ── External services (if applicable) ────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# STRIPE_SECRET_KEY=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ── Email (if applicable) ────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@example.com

# ── Object storage (if applicable, SeaweedFS) ────────────────────────
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=myapp
# S3_ENDPOINT=http://seaweed:8333

# ── Compose ──────────────────────────────────────────────────────────
DATA_DIR=./data                     # bind-mount root; override in prod
COMPOSE_PROJECT_NAME=myapp
